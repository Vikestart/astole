# Turn on the URL rewriting engine
RewriteEngine On

# Security: Prevent directory listing (so users can't browse your file folders)
Options -Indexes

# Condition 1: If the user requests an actual file (like a .css, .js, or .png file), serve it normally.
RewriteCond %{REQUEST_FILENAME} !-f

# Condition 2: If the user requests an actual directory (like your /adm/ folder), serve it normally.
RewriteCond %{REQUEST_FILENAME} !-d

# The Rule: If it's NOT a real file or directory, grab whatever they typed and send it to index.php
# The QSA flag (Query String Append) ensures that if you ever use ?var=true, it doesn't get erased.
# The L flag (Last) tells the server to stop processing any more rules below this one.
RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]